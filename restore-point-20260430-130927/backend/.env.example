DB_DATABASE=oportunidades
DB_SERVER=
DB_PORT=1433
DB_ENCRYPT=true

# SQL Server auth mode
# - Windows Auth (Integrated Security): set DB_INTEGRATED=true and leave DB_USER/DB_PASSWORD empty
# - SQL Auth: set DB_INTEGRATED=false and set DB_USER/DB_PASSWORD
DB_INTEGRATED=true
DB_USER=
DB_PASSWORD=
DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

JWT_SECRET=
JWT_REFRESH_SECRET=

# Reverse proxy configuration for Express (`app.set('trust proxy', ...)`)
# - Local dev: leave empty (defaults to false)
# - Behind a single proxy (most common): TRUST_PROXY=1
# - Trust only loopback: TRUST_PROXY=loopback
TRUST_PROXY=

APP_ORIGIN=http://localhost:3000
PORT=4000
